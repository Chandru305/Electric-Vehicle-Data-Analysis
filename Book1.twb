      <aliases enabled='yes' />
      <column caption='Total Vehicals' datatype='integer' name='[Calculation_843580545831047168]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([DOL Vehicle ID])' />
      </column>
      <column caption='Avg Electric range' datatype='real' name='[Calculation_843580545832153089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Electric Range])' />
      </column>
      <column caption='Total BEV Vehicles' datatype='integer' name='[Calculation_843580545835884546]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Electric Vehicle Type] = &quot;Battery Electric Vehicle (BEV)&quot;&#13;&#10;THEN [DOL Vehicle ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='% of BEV Vehicles' datatype='real' name='[Calculation_843580545837101059]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_843580545835884546]/[Calculation_843580545831047168]' />
      </column>
      <column caption='Total PHEV Vehicles' datatype='integer' name='[Calculation_843580545838039044]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [Electric Vehicle Type] = &quot;Plug-in Hybrid Electric Vehicle (PHEV)&quot;&#13;&#10;THEN&#13;&#10;[DOL Vehicle ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='% of PHEV Vehicles' datatype='real' name='[Calculation_843580545838661637]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_843580545838039044]/[Calculation_843580545831047168]' />
      </column>
